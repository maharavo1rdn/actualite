Options +FollowSymlinks
RewriteEngine On

# ═══════════════════════════════════════════════════════════════════
#  CANONICALS — Redirections 301 des anciens URLs physiques
# ═══════════════════════════════════════════════════════════════════

# index.php → /
RewriteCond %{THE_REQUEST} \s/+index\.php\s [NC]
RewriteRule ^index\.php$ / [R=301,L]

# article.php?s= → /article/*.html
RewriteCond %{THE_REQUEST} \s/+pages/articles/article\.php\?s=([^&\s]+) [NC]
RewriteRule ^pages/articles/article\.php$ /article/%1.html? [R=301,L,NE]

# Auth
RewriteCond %{THE_REQUEST} \s/+pages/users/login\.php\s [NC]
RewriteRule ^pages/users/login\.php$ /connexion [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/users/logout\.php\s [NC]
RewriteRule ^pages/users/logout\.php$ /deconnexion [R=301,L]

RewriteCond %{THE_REQUEST} \s/+controllers/traitement_login\.php\s [NC]
RewriteRule ^controllers/traitement_login\.php$ /auth/login [R=301,L]

RewriteCond %{THE_REQUEST} \s/+controllers/traitement_logout\.php\s [NC]
RewriteRule ^controllers/traitement_logout\.php$ /deconnexion [R=301,L]

# Chronologie
RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_evenements_chronologie\.php\?article_id=([0-9]+)\s [NC]
RewriteRule ^pages/articles/backoffice_evenements_chronologie\.php$ /backoffice/chronologie/article-%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_evenements_chronologie\.php\?edit_id=([0-9]+)\s [NC]
RewriteRule ^pages/articles/backoffice_evenements_chronologie\.php$ /backoffice/chronologie/edit-%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_evenements_chronologie_form\.php\s [NC]
RewriteRule ^pages/articles/backoffice_evenements_chronologie_form\.php$ /backoffice/chronologie/ajout [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_evenements_chronologie\.php\s [NC]
RewriteRule ^pages/articles/backoffice_evenements_chronologie\.php$ /backoffice/chronologie [R=301,L]

RewriteCond %{THE_REQUEST} \s/+controllers/traitement_evenements_chronologie\.php\s [NC]
RewriteRule ^controllers/traitement_evenements_chronologie\.php$ /backoffice/chronologie/traitement [R=301,L]

# Articles backoffice
RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_articles\.php\s [NC]
RewriteRule ^pages/articles/backoffice_articles\.php$ /backoffice/articles [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_articles_form\.php\?id=([0-9]+)\s [NC]
RewriteRule ^pages/articles/backoffice_articles_form\.php$ /backoffice/articles/edit-%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_articles_form\.php\s [NC]
RewriteRule ^pages/articles/backoffice_articles_form\.php$ /backoffice/articles/nouveau [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_sources\.php\s [NC]
RewriteRule ^pages/articles/backoffice_sources\.php$ /backoffice/sources [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_categories\.php\s [NC]
RewriteRule ^pages/articles/backoffice_categories\.php$ /backoffice/categories [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_types_sources\.php\s [NC]
RewriteRule ^pages/articles/backoffice_types_sources\.php$ /backoffice/types-sources [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/articles/backoffice_utilisateurs\.php\s [NC]
RewriteRule ^pages/articles/backoffice_utilisateurs\.php$ /backoffice/utilisateurs [R=301,L]

RewriteCond %{THE_REQUEST} \s/+controllers/traitement_articles\.php\s [NC]
RewriteRule ^controllers/traitement_articles\.php$ /backoffice/articles/traitement [R=301,L]

RewriteCond %{THE_REQUEST} \s/+controllers/traitement_backoffice\.php\s [NC]
RewriteRule ^controllers/traitement_backoffice\.php$ /backoffice/gestion/traitement [R=301,L]

# ═══════════════════════════════════════════════════════════════════
#  Fichiers et dossiers réels → servis directement (assets, etc.)
# ═══════════════════════════════════════════════════════════════════
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ═══════════════════════════════════════════════════════════════════
#  FRONT ROUTES
# ═══════════════════════════════════════════════════════════════════
RewriteRule ^$                                    index.php [L,QSA]
RewriteRule ^accueil/?$                           index.php [L,QSA]
RewriteRule ^actualites/?$                        index.php [L,QSA]
RewriteRule ^categorie/([_a-zA-Z0-9-]+)/?$        index.php?cat_slug=$1 [L,QSA]
RewriteRule ^article/([_a-zA-Z0-9-]+)\.html$      pages/articles/article.php?s=$1 [L,QSA]

# ═══════════════════════════════════════════════════════════════════
#  AUTH ROUTES
# ═══════════════════════════════════════════════════════════════════
RewriteRule ^connexion/?$                         pages/users/login.php [L,QSA]
RewriteRule ^deconnexion/?$                       controllers/traitement_logout.php [L,QSA]
RewriteRule ^logout/?$                            controllers/traitement_logout.php [L,QSA]
RewriteRule ^auth/login/?$                        controllers/traitement_login.php [L,QSA]

# ═══════════════════════════════════════════════════════════════════
#  BACKOFFICE ROUTES
# ═══════════════════════════════════════════════════════════════════

# Chronologie
RewriteRule ^backoffice/chronologie/?$                          pages/articles/backoffice_evenements_chronologie.php [L,QSA]
RewriteRule ^backoffice/chronologie/article-([0-9]+)/?$         pages/articles/backoffice_evenements_chronologie.php?article_id=$1 [L,QSA]
RewriteRule ^backoffice/chronologie/ajout/?$                    pages/articles/backoffice_evenements_chronologie_form.php [L,QSA]
RewriteRule ^backoffice/chronologie/ajout/article-([0-9]+)/?$   pages/articles/backoffice_evenements_chronologie_form.php?article_id=$1 [L,QSA]
RewriteRule ^backoffice/chronologie/edit-([0-9]+)/?$            pages/articles/backoffice_evenements_chronologie_form.php?edit_id=$1 [L,QSA]
RewriteRule ^backoffice/chronologie/traitement/?$               controllers/traitement_evenements_chronologie.php [L,QSA]

# Articles
RewriteRule ^backoffice/articles/?$                             pages/articles/backoffice_articles.php [L,QSA]
RewriteRule ^backoffice/articles/nouveau/?$                     pages/articles/backoffice_articles_form.php [L,QSA]
RewriteRule ^backoffice/articles/edit-([0-9]+)/?$               pages/articles/backoffice_articles_form.php?id=$1 [L,QSA]
RewriteRule ^backoffice/articles/traitement/?$                  controllers/traitement_articles.php [L,QSA]

# Sources
RewriteRule ^backoffice/sources/?$                              pages/articles/backoffice_sources.php [L,QSA]

# Catégories
RewriteRule ^backoffice/categories/?$                           pages/articles/backoffice_categories.php [L,QSA]

# Types de sources
RewriteRule ^backoffice/types-sources/?$                        pages/articles/backoffice_types_sources.php [L,QSA]

# Utilisateurs
RewriteRule ^backoffice/utilisateurs/?$                         pages/articles/backoffice_utilisateurs.php [L,QSA]

# Traitement CRUD Backoffice
RewriteRule ^backoffice/gestion/traitement/?$                   controllers/traitement_backoffice.php [L,QSA]

# Racine backoffice → liste articles (point d'entrée principal)
RewriteRule ^backoffice/?$                                      pages/articles/backoffice_articles.php [L,QSA]

# ═══════════════════════════════════════════════════════════════════
#  PERFORMANCE 
# ═══════════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresDefault "access plus 1 month"

	# Documents dynamiques: toujours revalidés
	ExpiresByType text/html "access plus 0 seconds"
	ExpiresByType application/json "access plus 0 seconds"
	ExpiresByType text/xml "access plus 0 seconds"
	ExpiresByType application/xml "access plus 0 seconds"

	# Assets statiques
	ExpiresByType text/css "access plus 1 year"
	ExpiresByType application/javascript "access plus 1 year"
	ExpiresByType text/javascript "access plus 1 year"

	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/avif "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 month"
	ExpiresByType image/x-icon "access plus 1 month"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"

	ExpiresByType font/woff2 "access plus 1 year"
	ExpiresByType font/woff "access plus 1 year"
	ExpiresByType font/ttf "access plus 1 year"
	ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
	# Cache long pour assets versionnés/statics
	<FilesMatch "\.(?:css|js|mjs|png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|eot)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>

	# Exception dev: éviter un cache figé du runtime Tailwind
	<Files "tailwind.js">
		Header set Cache-Control "public, max-age=3600"
	</Files>

	# HTML/PHP: éviter cache disque agressif
	<FilesMatch "\.(?:html?|php)$">
		Header set Cache-Control "no-cache, no-store, must-revalidate"
		Header set Pragma "no-cache"
		Header set Expires "0"
	</FilesMatch>

	# Indique aux proxys qu'il existe une variante compressée/non-compressée
	Header append Vary Accept-Encoding
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/plain
	AddOutputFilterByType DEFLATE text/html
	AddOutputFilterByType DEFLATE text/css
	AddOutputFilterByType DEFLATE text/javascript
	AddOutputFilterByType DEFLATE application/javascript
	AddOutputFilterByType DEFLATE application/json
	AddOutputFilterByType DEFLATE application/xml
	AddOutputFilterByType DEFLATE text/xml
	AddOutputFilterByType DEFLATE image/svg+xml

	# Ne pas recompresser les formats déjà compressés
	SetEnvIfNoCase Request_URI "\.(?:gif|jpe?g|png|webp|avif|ico|zip|gz|bz2|rar|7z|mp4|webm|mp3)$" no-gzip dont-vary
</IfModule>

# CORS police (utile si fonts servies depuis un autre sous-domaine/CDN plus tard)
<FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2)$">
	<IfModule mod_headers.c>
		Header set Access-Control-Allow-Origin "*"
	</IfModule>
</FilesMatch>
